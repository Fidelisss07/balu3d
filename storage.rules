rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isImage() {
      return request.resource.contentType in ['image/jpeg', 'image/png', 'image/webp'];
    }
    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // Carrosséis e produtos - upload apenas admin, leitura pública
    match /carousels/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && isUnder5MB();
    }

    match /products/{fileName=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && isUnder5MB();
    }

    // Bloqueia qualquer caminho não listado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
